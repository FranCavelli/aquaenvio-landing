---
import { whatsappUrl } from '../config';

// Filas de la comparativa. true = sí, false = no, string = detalle.
const features = [
  { f: 'Precio en pesos argentinos', aqua: true, yaku: 'En dólares (USD 48–96/mes)', gestion: 'No publica', app: 'Gratis / Premium' },
  { f: 'Prueba gratis sin tarjeta', aqua: '1 semana', yaku: '7 días', gestion: false, app: true },
  { f: 'Sin costo de implementación', aqua: true, yaku: 'USD 50–100 aparte', gestion: false, app: true },
  { f: 'App del repartidor (vende desde el celu)', aqua: true, yaku: true, gestion: true, app: true },
  { f: 'Funciona sin señal en la calle', aqua: true, yaku: false, gestion: false, app: false },
  { f: 'Control de envases / comodato', aqua: true, yaku: 'Plan medio+', gestion: true, app: true },
  { f: 'Facturación AFIP integrada (CAE real)', aqua: true, yaku: false, gestion: false, app: false },
  { f: 'Copiloto de IA por voz en el reparto', aqua: true, yaku: false, gestion: false, app: false },
  { f: 'Mapas de clientes y repartidores', aqua: true, yaku: true, gestion: 'Parcial', app: 'Parcial' },
  { f: 'Caja y gastos', aqua: true, yaku: true, gestion: true, app: true },
  { f: 'Soporte humano por WhatsApp', aqua: true, yaku: 'Plan pro', gestion: true, app: 'Limitado en gratis' },
  { f: 'Diseño moderno / mobile-first', aqua: true, yaku: true, gestion: false, app: 'Básico' },
];

const cols = [
  { key: 'aqua', name: 'AquaEnvio', highlight: true },
  { key: 'yaku', name: 'Yaku' },
  { key: 'gestion', name: 'Gestión Aguas' },
  { key: 'app', name: 'App Delivery Agua' },
];
---

<section id="comparativa" class="scroll-mt-24 bg-slate-50 py-16 sm:py-24">
  <div class="mx-auto max-w-5xl px-4">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="text-sm font-semibold text-cyan-600">Comparativa</span>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        AquaEnvio vs los demás sistemas
      </h2>
      <p class="mt-3 text-slate-500">
        Cómo se compara con los principales software de reparto de agua de Argentina,
        en lo que de verdad importa para una sodería o distribuidora.
      </p>
    </div>

    <!-- Tabla -->
    <div class="mt-12 overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm" data-reveal>
      <table class="w-full min-w-[640px] border-collapse text-sm">
        <thead>
          <tr class="bg-slate-50">
            <th class="px-4 py-4 text-left font-semibold text-slate-500">Característica</th>
            {cols.map((c) => (
              <th class={`px-4 py-4 text-center font-bold ${c.highlight ? 'bg-aqua-700 text-white' : 'text-slate-700'}`}>
                {c.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {features.map((row, i) => (
            <tr class={i % 2 ? 'bg-white' : 'bg-slate-50/40'}>
              <td class="px-4 py-3 text-left font-medium text-slate-700">{row.f}</td>
              {cols.map((c) => {
                const v = row[c.key];
                return (
                  <td class={`px-4 py-3 text-center ${c.highlight ? 'bg-cyan-50/70 font-medium text-aqua-900' : 'text-slate-600'}`}>
                    {v === true ? (
                      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      </span>
                    ) : v === false ? (
                      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-100 text-slate-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                      </span>
                    ) : (
                      <span class="text-xs">{v}</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-center text-xs text-slate-400">
      Datos públicos de cada proveedor a junio 2026.
    </p>

    <!-- Lo que solo tenés en AquaEnvio -->
    <div class="mt-14 grid gap-5 sm:grid-cols-3" data-reveal-group>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" data-reveal-item>
        <div class="text-2xl">🧾</div>
        <h3 class="mt-3 font-bold text-slate-800">Facturación AFIP de verdad</h3>
        <p class="mt-1.5 text-sm text-slate-500">Emití comprobantes con CAE y QR desde el sistema. Ninguno de los otros lo tiene integrado.</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" data-reveal-item>
        <div class="text-2xl">🎙️</div>
        <h3 class="mt-3 font-bold text-slate-800">Copiloto de IA por voz</h3>
        <p class="mt-1.5 text-sm text-slate-500">Le dicta al repartidor a quién venderle más y qué clientes están flojos. Único en el rubro.</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" data-reveal-item>
        <div class="text-2xl">📶</div>
        <h3 class="mt-3 font-bold text-slate-800">Vende sin señal</h3>
        <p class="mt-1.5 text-sm text-slate-500">El repartidor carga la venta aunque no haya internet y se sincroniza al volver la conexión.</p>
      </div>
    </div>

    <div class="mt-10 text-center" data-reveal>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-blue-600/30 transition hover:-translate-y-0.5 hover:bg-blue-700">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
        Probar AquaEnvio gratis
      </a>
    </div>
  </div>
</section>
