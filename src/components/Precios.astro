---
import { whatsappUrl } from '../config';

// Esquema simple Gratis (muy limitada) / Premium. Los detalles de cada plan se
// ajustan acá (bullets y CTA); el precio exacto de Premium se define con el usuario.
const planes = [
  {
    nombre: 'Gratis',
    tag: 'Muy limitada',
    desc: 'Para arrancar y probar el sistema sin pagar nada.',
    destacado: false,
    items: [
      'Un reparto',
      'Carga de clientes y ventas',
      'Caja del día',
    ],
    cta: 'Empezar gratis',
  },
  {
    nombre: 'Premium',
    tag: 'Todo incluido',
    desc: 'Toda la operación de tu distribuidora, sin límites.',
    destacado: true,
    items: [
      'Repartos, clientes y envases ilimitados',
      'Mapas en vivo y dashboard',
      'Facturación AFIP + copiloto de IA',
      'Soporte por WhatsApp',
    ],
    cta: 'Probar 1 semana gratis',
  },
];
---

<section id="precios" class="scroll-mt-24 bg-slate-50 py-16 sm:py-24">
  <div class="mx-auto max-w-4xl px-4">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="text-sm font-semibold text-cyan-600">Precio</span>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Elegí cómo empezar</h2>
      <p class="mt-3 text-slate-500">
        Probá gratis y pasate a Premium cuando quieras. Suscripción mensual en pesos, sin permanencia.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2" data-reveal-group>
      {planes.map((p) => (
        <div
          data-reveal-item
          class={`relative rounded-3xl border p-6 sm:p-8 ${p.destacado ? 'border-aqua-700 bg-white shadow-xl ring-2 ring-aqua-700/15' : 'border-slate-200 bg-white shadow-sm'}`}
        >
          {p.destacado && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-aqua-700 px-3 py-1 text-xs font-semibold text-white shadow">
              Recomendado
            </span>
          )}
          <div class="flex items-baseline justify-between gap-2">
            <h3 class="text-xl font-bold text-slate-900">{p.nombre}</h3>
            <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold ${p.destacado ? 'bg-cyan-100 text-cyan-700' : 'bg-slate-100 text-slate-500'}`}>
              {p.tag}
            </span>
          </div>
          <p class="mt-2 text-sm text-slate-500">{p.desc}</p>
          <ul class="mt-5 space-y-2.5">
            {p.items.map((it) => (
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-cyan-600"><path d="M20 6 9 17l-5-5"/></svg>
                {it}
              </li>
            ))}
          </ul>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class={`mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition ${p.destacado ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/30 hover:-translate-y-0.5 hover:bg-blue-700' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}
          >
            {p.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
