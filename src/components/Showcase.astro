---
import VideoTile from './VideoTile.astro';
---

<!-- "Vender es un toque" — la app en el celular, dentro de un mockup -->
<section id="app" class="scroll-mt-24 bg-white py-16 sm:py-24">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 lg:grid-cols-2">
    <div data-reveal>
      <span class="text-sm font-semibold text-cyan-600">En el celular del repartidor</span>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Vender es un toque</h2>
      <p class="mt-3 max-w-md text-slate-500">
        Pensada para el día a día en la calle: rápida, simple y a prueba de zonas sin señal.
      </p>
      <ul class="mt-6 space-y-3">
        {
          [
            'Ordená el reparto y registrá la venta en segundos.',
            'Funciona sin señal: se guarda y sincroniza solo.',
            '"Para mañana" y pedidos fijados arriba de la lista.',
            'Envases, transferencias y saldo del cliente al toque.',
          ].map((b) => (
            <li class="flex items-start gap-2.5 text-sm text-slate-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-cyan-600"><path d="M20 6 9 17l-5-5"/></svg>
              {b}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Mockup de celular -->
    <div class="flex justify-center" data-reveal>
      <div class="relative w-[260px] sm:w-[290px]">
        <!-- resplandor detrás -->
        <div class="pointer-events-none absolute inset-0 -z-10 scale-110 rounded-[3rem] bg-cyan-400/25 blur-3xl"></div>
        <!-- cuerpo del teléfono -->
        <div class="relative rounded-[2.75rem] bg-slate-950 p-3 shadow-2xl ring-1 ring-black/10">
          <!-- pantalla (completa, sin notch) -->
          <div class="overflow-hidden rounded-[2rem] bg-slate-950">
            <VideoTile
              src="/videos/mobile-reparto.mp4"
              poster="/images/mobile-reparto.jpg"
              label="Reparto en el celular"
              ratio="aspect-[9/19]"
            />
          </div>
        </div>
        <!-- botones laterales -->
        <div class="absolute -right-1 top-24 h-16 w-1 rounded-r bg-slate-800"></div>
        <div class="absolute -left-1 top-20 h-10 w-1 rounded-l bg-slate-800"></div>
        <div class="absolute -left-1 top-32 h-10 w-1 rounded-l bg-slate-800"></div>
      </div>
    </div>
  </div>
</section>
