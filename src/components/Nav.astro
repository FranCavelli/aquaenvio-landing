---
import { whatsappUrl, mailtoUrl } from '../config';

interface Props {
  base?: string; // '' en el home (scroll suave); '/' en otras pÃ¡ginas (vuelve al home)
}
const { base = '' } = Astro.props;

const links = [
  { href: `${base}#app`, label: 'La app' },
  { href: `${base}#funciones`, label: 'Funciones' },
  { href: `${base}#comparativa`, label: 'Comparativa' },
  { href: `${base}#calculadora`, label: 'Precio' },
];
---

<header
  id="nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-nav
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3.5">
    <a href={`${base}#top`} class="flex items-center gap-2 text-white" data-nav-logo>
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/25 backdrop-blur">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-200">
          <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"></path>
          <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"></path>
        </svg>
      </span>
      <span class="text-lg font-extrabold tracking-tight">Aquaenvio</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" data-nav-links>
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-full px-3.5 py-2 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={mailtoUrl}
        class="hidden items-center gap-1.5 rounded-full bg-white/10 px-3 py-2 text-sm font-semibold text-white ring-1 ring-white/20 backdrop-blur transition hover:bg-white/15 sm:inline-flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Mail
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
        WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  // Smooth scroll en los anchors internos (#funciones, #app, etc.). Animado a
  // mano con requestAnimationFrame para que funcione SIEMPRE, incluso con
  // "reducir movimiento" activado (que convierte el scroll suave nativo en salto).
  const NAV_OFFSET = 80; // alto aprox del nav fijo

  function smoothTo(targetY: number, duration = 650) {
    const startY = window.scrollY;
    const dist = targetY - startY;
    if (Math.abs(dist) < 2) return;
    let t0: number | null = null;
    function step(ts: number) {
      if (t0 === null) t0 = ts;
      const p = Math.min((ts - t0) / duration, 1);
      const e = p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2; // easeInOutQuad
      window.scrollTo(0, startY + dist * e);
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const id = a.getAttribute('href')?.slice(1);
      if (!id) return;
      const el = id === 'top' ? document.body : document.getElementById(id);
      if (!el) return;
      e.preventDefault();
      const targetY = id === 'top' ? 0 : el.getBoundingClientRect().top + window.scrollY - NAV_OFFSET;
      smoothTo(targetY);
      history.pushState(null, '', '#' + id);
    });
  });
</script>
