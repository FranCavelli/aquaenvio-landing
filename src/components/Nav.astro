---
import { whatsappUrl, mailtoUrl } from '../config';

const links = [
  { href: '#app', label: 'La app' },
  { href: '#funciones', label: 'Funciones' },
  { href: '#galeria', label: 'Capturas' },
  { href: '#calculadora', label: 'Precio' },
];
---

<header
  id="nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-nav
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3.5">
    <a href="#top" class="flex items-center gap-2 text-white" data-nav-logo>
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/25 backdrop-blur">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-200">
          <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C4 11.1 3 13 3 15a7 7 0 0 0 7 7Z"></path>
        </svg>
      </span>
      <span class="text-lg font-extrabold tracking-tight">AquaEnvio</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" data-nav-links>
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-full px-3.5 py-2 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={mailtoUrl}
        class="hidden items-center gap-1.5 rounded-full bg-white/10 px-3 py-2 text-sm font-semibold text-white ring-1 ring-white/20 backdrop-blur transition hover:bg-white/15 sm:inline-flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Mail
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
        WhatsApp
      </a>
    </div>
  </div>
</header>
