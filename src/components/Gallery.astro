---
import VideoTile from './VideoTile.astro';

const capturas = [
  { src: '/videos/dashboard.mp4', poster: '/images/dashboard.jpg', t: 'Tablero en tiempo real', d: 'Cobrado, vendido, bidones y clientes del día, con gráficos por mes.' },
  { src: '/videos/reparto.mp4', poster: '/images/reparto.jpg', t: 'Reparto operativo', d: 'Ordená el recorrido y registrá ventas y envases en segundos.' },
  { src: '/videos/mapa.mp4', poster: '/images/mapa.jpg', t: 'Mapa en vivo', d: 'Clientes y repartidores ubicados en tiempo real.' },
  { src: '/videos/clientes.mp4', poster: '/images/clientes.jpg', t: 'Clientes y saldos', d: 'Ficha, precios por cliente, historial y buscador al instante.' },
  { src: '/videos/caja.mp4', poster: '/images/caja.jpg', t: 'Caja y gastos', d: 'Caja diaria y control de gastos, con cierre y seguimiento.' },
];
---

<section id="galeria" class="scroll-mt-24 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="text-sm font-semibold text-cyan-600">La app por dentro</span>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Todo tu día, en una pantalla
      </h2>
      <p class="mt-3 text-slate-500">
        Repartos, ventas, clientes, caja y mapas en vivo. Tocá una captura para ampliarla.
      </p>
    </div>

    <div class="mt-12 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
      {
        capturas.map((c) => (
          <button
            type="button"
            data-reveal-item
            class="lightbox-trigger group relative block w-full overflow-hidden rounded-2xl text-left shadow-lg shadow-slate-900/15 ring-1 ring-slate-200/70 transition duration-300 hover:-translate-y-1 hover:shadow-2xl"
            data-src={c.src}
            data-poster={c.poster}
            data-title={c.t}
            aria-label={`Ampliar: ${c.t}`}
          >
            <VideoTile src={c.src} poster={c.poster} label={c.t} ratio="aspect-[16/10]" />
            {/* Título + descripción dentro de la captura, con degradado en la mitad inferior */}
            <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-slate-950/90 via-slate-950/55 to-transparent px-4 pb-4 pt-16">
              <h3 class="text-base font-semibold text-white drop-shadow">{c.t}</h3>
              <p class="mt-0.5 text-xs leading-relaxed text-white/85 drop-shadow">{c.d}</p>
            </div>
          </button>
        ))
      }
    </div>
  </div>

  <!-- Lightbox: ampliar la captura al hacer click -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[80] hidden items-center justify-center bg-slate-950/85 p-4 backdrop-blur-sm"
  >
    <button
      id="lightbox-close"
      type="button"
      aria-label="Cerrar"
      class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white ring-1 ring-white/20 transition hover:bg-white/20"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <figure class="w-full max-w-4xl">
      <div class="overflow-hidden rounded-2xl shadow-2xl ring-1 ring-white/10">
        <video id="lightbox-video" class="block w-full" autoplay loop muted playsinline controls></video>
      </div>
      <figcaption id="lightbox-title" class="mt-3 text-center text-sm font-medium text-white/80"></figcaption>
    </figure>
  </div>
</section>

<script>
  const lb = document.getElementById('lightbox') as HTMLElement | null;
  const vid = document.getElementById('lightbox-video') as HTMLVideoElement | null;
  const title = document.getElementById('lightbox-title') as HTMLElement | null;

  function openLb(src: string, poster: string, t: string) {
    if (!lb || !vid) return;
    vid.src = src;
    if (poster) vid.poster = poster;
    if (title) title.textContent = t;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
    vid.play().catch(() => {});
  }

  function closeLb() {
    if (!lb || !vid) return;
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    vid.pause();
    vid.removeAttribute('src');
    vid.load();
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLElement>('.lightbox-trigger').forEach((b) => {
    b.addEventListener('click', () =>
      openLb(b.dataset.src || '', b.dataset.poster || '', b.dataset.title || '')
    );
  });
  document.getElementById('lightbox-close')?.addEventListener('click', closeLb);
  lb?.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lb && !lb.classList.contains('hidden')) closeLb();
  });
</script>
