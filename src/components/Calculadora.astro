---
import { whatsappUrl } from '../config';
---

<section id="calculadora" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-16 sm:py-24">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="text-sm font-semibold text-cyan-600">Precio</span>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      Calculá tu plan
    </h2>
    <p class="mt-3 text-slate-500">
      Pagás según tu uso. Movés los valores y ves el precio al instante.
    </p>
  </div>

  <div class="mx-auto mt-12 grid max-w-4xl items-start gap-5 lg:grid-cols-[1.15fr_0.85fr]" data-reveal>
    <!-- Controles -->
    <div class="rounded-3xl bg-white p-6 shadow-xl ring-1 ring-black/5 sm:p-8">
      <!-- Usuarios -->
      <div>
        <div class="mb-2 flex items-end justify-between gap-3">
          <label class="flex items-center gap-2 text-sm font-medium text-slate-700" for="calc-usuarios-num">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-600"><path d="M16 7a4 4 0 1 0-8 0"/><circle cx="12" cy="7" r="4"/><path d="M12 11v8"/><path d="M8 21h8"/></svg>
            Usuarios
            <span class="font-normal text-slate-400">· repartidores, depósito y admin</span>
          </label>
          <input
            id="calc-usuarios-num"
            type="number"
            value="1"
            min="1"
            max="30"
            class="num w-24 rounded-lg border border-slate-200 bg-slate-50/70 px-2 py-1 text-right text-lg font-semibold text-slate-800 outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/25"
          />
        </div>
        <input id="calc-usuarios" type="range" value="1" min="1" max="30" step="1" class="w-full cursor-pointer" />
        <div class="mt-1 flex justify-between text-[11px] text-slate-400"><span>1</span><span>30+</span></div>
      </div>

      <div class="h-6"></div>

      <!-- Clientes -->
      <div>
        <div class="mb-2 flex items-end justify-between gap-3">
          <label class="flex items-center gap-2 text-sm font-medium text-slate-700" for="calc-clientes-num">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-600"><path d="M16 7a4 4 0 1 0-8 0"/><path d="M12 11v8"/><path d="M8 21h8"/><circle cx="12" cy="7" r="4"/></svg>
            Clientes
            <span class="font-normal text-slate-400">· cargados en el sistema</span>
          </label>
          <input
            id="calc-clientes-num"
            type="number"
            value="300"
            min="0"
            max="3000"
            step="10"
            class="num w-24 rounded-lg border border-slate-200 bg-slate-50/70 px-2 py-1 text-right text-lg font-semibold text-slate-800 outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/25"
          />
        </div>
        <input id="calc-clientes" type="range" value="300" min="0" max="3000" step="10" class="w-full cursor-pointer" />
        <div class="mt-1 flex justify-between text-[11px] text-slate-400"><span>0</span><span>3.000+</span></div>
      </div>

      <p class="mt-7 text-xs leading-relaxed text-slate-400">
        El precio se expresa en pesos al valor del dólar del día. Sin costos de
        instalación ni permanencia.
      </p>
    </div>

    <!-- Resultado -->
    <div class="rounded-3xl bg-gradient-to-br from-cyan-500 to-blue-600 p-6 text-white shadow-xl sm:p-8">
      <p class="text-sm text-cyan-50/80">Tu plan</p>
      <p id="calc-ars" class="num mt-1 text-5xl font-bold leading-none">—</p>
      <p class="mt-1 text-sm text-cyan-50/80">
        por mes <span id="calc-loading" class="text-cyan-50/60">· cargando cotización…</span>
      </p>
      <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 text-xs font-medium backdrop-blur">
        <span id="calc-usd">US$ 0</span>/mes · dólar blue
      </div>
      <div class="my-6 h-px bg-white/20"></div>
      <p class="mb-3 text-sm font-medium text-cyan-50/90">
        Incluye todos los módulos, actualizaciones y soporte.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-blue-700 shadow transition hover:bg-cyan-50"
      >
        Quiero contratarlo
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </div>

  <p class="mx-auto mt-6 max-w-2xl text-center text-xs text-slate-400">
    Precio estimado, sujeto a confirmación. Se actualiza con la cotización del dólar del día.
  </p>
</section>

<script>
  import '../scripts/calculator.ts';
</script>
