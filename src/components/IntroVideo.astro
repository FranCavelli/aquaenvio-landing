---
/**
 * Sección de video de introducción.
 * Para usar tu video: dejá el archivo en  /public/videos/intro.mp4
 * (opcional: un poster en /public/images/intro-poster.jpg).
 * Mientras no exista, se muestra el cartel "Poné tu video de introducción aquí".
 */
---

<section id="video" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-16 sm:py-24">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="text-sm font-semibold text-cyan-600">Mirá cómo funciona</span>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      AquaEnvio en 60 segundos
    </h2>
    <p class="mt-3 text-slate-500">
      Una recorrida rápida por la app, del reparto al dashboard.
    </p>
  </div>

  <div
    class="relative mx-auto mt-10 aspect-video w-full max-w-4xl overflow-hidden rounded-3xl bg-slate-900 shadow-2xl ring-1 ring-black/10"
    data-reveal
  >
    <!-- Placeholder (queda detrás del video; si el video no carga, se ve esto) -->
    <div
      id="video-ph"
      class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-aqua-900 via-aqua-800 to-aqua-700 p-6 text-center text-white"
    >
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/15 ring-1 ring-white/25 backdrop-blur">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="ml-1 text-cyan-200">
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </div>
      <p class="text-base font-semibold">Poné tu video de introducción aquí</p>
      <p class="font-mono text-xs text-cyan-100/70">/public/videos/intro.mp4</p>
    </div>

    <!-- Video real: aparece solo si dejás el archivo. Si no existe, se oculta. -->
    <video
      class="absolute inset-0 h-full w-full bg-transparent object-cover"
      controls
      playsinline
      preload="metadata"
      poster="/images/intro-poster.jpg"
      onerror="this.style.display='none'"
    >
      <source src="/videos/intro.mp4" type="video/mp4" />
    </video>
  </div>
</section>
