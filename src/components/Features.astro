---
// Mismos módulos que la app / la landing /cotizar.
const modulos = [
  { t: 'Repartos', d: 'Ordená el recorrido, registrá ventas y envases, y deshacé con un toque.', icon: '<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/>' },
  { t: 'Clientes', d: 'Ficha completa, saldo, precios por cliente e historial de compras.', icon: '<path d="M16 7a4 4 0 1 0-8 0"/><path d="M12 11v8"/><path d="M8 21h8"/><circle cx="12" cy="7" r="4"/>' },
  { t: 'Ventas e historial', d: 'Cobros, transferencias y totales del día al instante.', icon: '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>' },
  { t: 'Pedidos y "para mañana"', d: 'Avisos de pedidos y clientes a visitar, fijados arriba hasta venderles.', icon: '<path d="M11 13.73 4 21"/><path d="M21 3 13.73 11"/><path d="m21 3-8 8"/><path d="M18 2a2 2 0 0 1 2 2"/>' },
  { t: 'Carga y descarga', d: 'Carga del camión, cierre y control de bidones vacíos y retorno.', icon: '<path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>' },
  { t: 'Caja y gastos', d: 'Caja diaria y gastos, con cierre y seguimiento.', icon: '<rect width="20" height="14" x="2" y="5" rx="2"/><path d="M12 12h.01"/>' },
  { t: 'Mapas en vivo', d: 'Clientes y repartidores en el mapa, ubicación en tiempo real.', icon: '<path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/>' },
  { t: 'Dashboard', d: 'Cobrado, vendido, bidones y reportes por mes y por día.', icon: '<path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/>' },
];
---

<section id="funciones" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-16 sm:py-24">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="text-sm font-semibold text-cyan-600">Funciones</span>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      Todo lo que necesitás, en un lugar
    </h2>
    <p class="mt-3 text-slate-500">
      Un módulo para cada parte de tu operación. Sin planillas ni cuadernos.
    </p>
  </div>

  <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
    {
      modulos.map((m) => (
        <div class="group rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200/70 transition duration-300 hover:-translate-y-1 hover:shadow-lg" data-reveal-item>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 text-white shadow-sm transition group-hover:scale-105">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon} />
          </div>
          <h3 class="mt-4 font-semibold text-slate-800">{m.t}</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-500">{m.d}</p>
        </div>
      ))
    }
  </div>
</section>
