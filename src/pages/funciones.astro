---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Showcase from '../components/Showcase.astro';
import Features from '../components/Features.astro';
import Diferenciales from '../components/Diferenciales.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const title = 'Funciones del software de reparto de agua | AquaEnvio';
const description =
  'Repartos, clientes, ventas, pedidos, carga y descarga, caja, mapas en vivo y dashboard. Todo lo que una sodería o distribuidora de agua necesita, en una sola app.';
---

<Base title={title} description={description} path="/funciones">
  <Nav base="/" />
  <main>
    <PageHeader
      badge="Funciones"
      title="Todo lo que tu sodería necesita, en una sola app"
      subtitle="Un módulo para cada parte de tu operación: repartos, clientes, ventas, envases, caja, mapas y reportes. Sin planillas ni cuadernos."
    />
    <Showcase />
    <Features />
    <Diferenciales />
    <CTA />
  </main>
  <Footer />
</Base>
