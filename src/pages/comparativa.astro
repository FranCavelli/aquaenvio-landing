---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Comparativa from '../components/Comparativa.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const title = 'AquaEnvio vs Yaku, Gestión Aguas y App Delivery Agua — comparativa';
const description =
  'Comparativa de software para reparto de agua en Argentina. AquaEnvio: precio en pesos, facturación AFIP integrada y copiloto de IA que ningún otro sistema tiene. Probalo gratis 1 semana.';
---

<Base title={title} description={description} path="/comparativa">
  <Nav base="/" />
  <main>
    <PageHeader
      badge="Comparativa honesta"
      title="AquaEnvio vs los demás sistemas de reparto de agua"
      subtitle="Comparamos AquaEnvio con los principales software del rubro en Argentina —Yaku, Gestión Aguas y App Delivery Agua— en lo que de verdad importa para una sodería o distribuidora."
    />
    <Comparativa />
    <CTA />
  </main>
  <Footer />
</Base>
