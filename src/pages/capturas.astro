---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Gallery from '../components/Gallery.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const title = 'Capturas de la app de reparto de agua | AquaEnvio';
const description =
  'Mirá la app por dentro: tablero en tiempo real, reparto operativo, mapa en vivo, clientes y saldos, caja y gastos. Así se ve el día a día de tu distribuidora en AquaEnvio.';
---

<Base title={title} description={description} path="/capturas">
  <Nav base="/" />
  <main>
    <PageHeader
      badge="La app por dentro"
      title="Mirá cómo se ve AquaEnvio"
      subtitle="Tablero, reparto, mapa en vivo, clientes y caja. Tocá una captura para ampliarla."
    />
    <Gallery />
    <CTA />
  </main>
  <Footer />
</Base>
