---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Precios from '../components/Precios.astro';
import Diferenciales from '../components/Diferenciales.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const title = 'Precio del software de reparto de agua en pesos | AquaEnvio';
const description =
  'Versión gratis (limitada) y plan Premium con todo incluido. Suscripción mensual en pesos argentinos, sin costo de implementación y con 1 semana de prueba gratis.';
---

<Base title={title} description={description} path="/precio">
  <Nav base="/" />
  <main>
    <PageHeader
      badge="Precio"
      title="Empezá gratis, crecé con Premium"
      subtitle="Una versión gratis (limitada) para arrancar y un plan Premium con todo incluido. Suscripción mensual en pesos, sin permanencia."
    />
    <Precios />
    <Diferenciales />
    <CTA />
  </main>
  <Footer />
</Base>
