---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  path?: string; // ruta para el canonical, ej: "/comparativa"
  ogImage?: string;
}

const {
  title = 'Aquaenvio Â· Software para reparto de agua, soda y soderÃ­as',
  description = 'Sistema argentino para distribuidoras de agua y soda: repartos, clientes, envases, caja y facturaciÃ³n AFIP desde el celular del repartidor (anda sin seÃ±al). Probalo gratis 1 semana.',
  path = '/',
  ogImage = 'https://aquaenvio.com/images/og.jpg',
} = Astro.props;

const SITE = 'https://aquaenvio.com';
const canonical = SITE + path;

// Datos estructurados para Google (rich results de software/precio).
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Aquaenvio',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, Android, iOS',
  description,
  url: SITE,
  inLanguage: 'es-AR',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'ARS',
    description: 'SuscripciÃ³n mensual en pesos. 1 semana de prueba gratis sin tarjeta.',
  },
  areaServed: { '@type': 'Country', name: 'Argentina' },
  audience: {
    '@type': 'BusinessAudience',
    name: 'SoderÃ­as y distribuidoras de agua, soda y bebidas',
  },
};
---

<!doctype html>
<html lang="es" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="software reparto de agua, sistema para soderÃ­a, app reparto de agua, gestiÃ³n distribuidora de agua, software soda y agua, control de envases, facturaciÃ³n AFIP soderÃ­a, reparto de agua Argentina" />
    <meta name="theme-color" content="#0a2e4d" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <!-- Open Graph (preview en WhatsApp / redes) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Aquaenvio" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Datos estructurados para Google -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Fuente Inter (carga no bloqueante) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      />
    </noscript>

    <title>{title}</title>

    <!-- Quita la clase no-js apenas corre JS -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>
    <noscript>
      <style>[data-reveal]{opacity:1;transform:none}</style>
    </noscript>
  </head>
  <body class="bg-slate-50 text-slate-800 overflow-x-hidden">
    <slot />

    <!-- Animaciones globales (GSAP + ScrollTrigger) -->
    <script>
      import '../scripts/animations.ts';
    </script>

    <!-- Registro de visita (IP + ubicaciÃ³n vÃ­a Cloudflare) en el backend de la app.
         Best-effort, fire-and-forget; el server dedup 1 por IP cada 30 min. -->
    <script is:inline>
      (function () {
        try {
          var url = 'https://aquaenvio.sbs/api/cotizar/visita?origen=landing';
          if (navigator.sendBeacon) navigator.sendBeacon(url);
          else fetch(url, { method: 'POST', mode: 'no-cors', keepalive: true }).catch(function () {});
        } catch (e) {}
      })();
    </script>
  </body>
</html>
